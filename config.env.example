# Copy to config.env and fill in. Or run from repo root with ../bsc-sniper/config.env.
# Required
RPC_URL=https://bsc-dataseed.binance.org
WSS_URL=wss://bsc-dataseed.binance.org
PRIVATE_KEY=0x...

# Optional: 0-block relay (mempool)
RELAY_CMD=/path/to/txstream
RELAY_ENDPOINT=host:50051
API_KEY=your-api-key

# Optional: BlockRazor tx confirmation (buy txs sent here first, then RPC fallback)
SENDTX_CMD=/path/to/bsc-transaction-decoder/sendtx
# BLOCKRAZOR_FAST_MODE_URL=...
# BLOCKRAZOR_FAST_AUTH=...

# Buy amounts (BNB)
FLAP_BUY_BNB=0.000001
FOURMEME_BUY_BNB=0.000001

# Gas
GAS_LIMIT=50000
GAS_GWEI=5
MAX_GAS_GWEI=5
PRIORITY_GAS_MULTIPLIER=1.01

# What to snipe (set SNIPE_FLAP=false for FourMeme-only test)
SNIPE_FLAP=true
SNIPE_FOURMEME=true

NONCE_REFRESH_INTERVAL=1.5

# Optional forwarder
# BLOCKRAZOR_FORWARDER_ADDRESS=0x...
